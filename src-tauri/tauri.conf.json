{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AFKode",
  "version": "0.8.3",
  "identifier": "app.afkode.overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "AFKode",
        "width": 1040,
        "height": 700,
        "minWidth": 520,
        "minHeight": 340,
        "center": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": true,
        "fullscreen": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-background-timer-throttling"
      },
      {
        "label": "hud",
        "title": "AFKode HUD",
        "url": "hud.html",
        "width": 340,
        "height": 44,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "x": 40,
        "y": 40
      },
      {
        "label": "palette",
        "title": "AFKode Prompt",
        "url": "palette.html",
        "width": 600,
        "height": 96,
        "center": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src ipc: http://ipc.localhost",
      "devCsp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzRjJFMjlEQTUwOTg3N0EKUldSNmh3bWxuZUx5by9RMldpUmhTMG40VUpTT3AyYU1BaFNzNWdoTXl6VTB2VW1mZlllenBKaCsK",
      "endpoints": [
        "https://github.com/ohernandezdev/afkode/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
